        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        display: block;
    }
    .promo-content h2 {
        font-size: 2rem;
        font-weight: 600;
        color: #1d2a34;
        margin-bottom: 20px;
    }
    .promo-content p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: #42545e;
        margin-bottom: 20px;
    }
    .promo-features {
        list-style: none;
        padding: 0;
    }
    .promo-features li {
        font-size: 1rem;
        color: #42545e;
        margin-bottom: 10px;
        position: relative;
        padding-left: 25px;
    }
    .promo-features li:before {
        content: '✓';
        color: #e7ca24;
        font-weight: bold;
        position: absolute;
        left: 0;
    }
    @media (max-width: 768px) {
        .booking-section {
            padding: 40px 20px;
        }
        .promo-section {
            padding: 40px 20px;
        }
        .promo-wrapper {
            flex-direction: column;
        }
    }
</style>

<section class="booking-section">
    <h2>Book Boardroom Perth - Select Duration</h2>
    <p class="location">Location: 598 Albany Highway, Victoria Park, Perth WA</p>
    <div class="booking-form">
        <label for="duration">Choose Booking Duration:</label>
        <select id="duration">
            <option value="1">1 Hour Meeting Room</option>
            <option value="2">2 Hours Boardroom Rental</option>
            <option value="3">3 Hours Office Space Booking</option>
            <option value="4">4 Hours Professional Meeting Room</option>
        </select>
        <br>
        <button onclick="bookNow()">Book Now</button>
    </div>
</section>

<section class="promo-section">
    <div class="promo-wrapper">
        <div class="promo-image">
            <img src="https://jordan09090.github.io/C88/Boardroom-800x600-1.png" alt="Boardroom desk setup in Victoria Park Perth office space">
        </div>
        <div class="promo-content">
            <h2>Premium Boardroom Facilities in Perth</h2>
            <p>Our boardroom in Victoria Park offers high-speed internet, comfortable ergonomic seating, and state-of-the-art presentation tools. Perfect for client meetings, team collaborations, or virtual conferences in Perth. Enjoy 24/7 access in a secure, professional environment with modern AV equipment and Wi-Fi connectivity.</p>
            <ul class="promo-features">
                <li>Modern AV equipment for presentations</li>
                <li>High-speed Wi-Fi throughout</li>
                <li>Comfortable seating for up to 12 people</li>
                <li>Professional kitchen access included</li>
                <li>24/7 secure access in Victoria Park</li>
            </ul>
            <a class="promo-button" href="https://offios.space/services/" target="_blank" rel="noopener noreferrer">Learn More About the Office Space</a>
        </div>
    </div>
</section>

<script>
function bookNow() {
    const duration = document.getElementById('duration').value;
    let url;
    switch (duration) {
        case '1':
            url = 'https://example.com/book-1h';
            break;
        case '2':
            url = 'https://example.com/book-2h';
            break;
        case '3':
            url = 'https://example.com/book-3h';
            break;
        case '4':
            url = 'https://example.com/book-4h';
            break;
        default:
            url = 'https://example.com/book';
    }
    window.open(url, '_blank');
}
</script>

